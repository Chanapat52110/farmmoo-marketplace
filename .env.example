# ══════════════════════════════════════════════════════════════════════════════
# FarmMoo — environment variable template
# Copy this file to .env and fill in the values.
# .env is git-ignored; NEVER commit secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Django Core ────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (no scheme/port)
# Production example: ALLOWED_HOSTS=farmmoo.com,www.farmmoo.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ───────────────────────────────────────────────────────────────────
# --- SQLite (default for local dev, no extra setup) ---
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# --- PostgreSQL (recommended for production) ---
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=farmmoo
# DB_USER=farmmoo
# DB_PASSWORD=your-strong-db-password
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=require          # require | prefer | disable

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (with scheme + port)
# Production example: CORS_ALLOWED_ORIGINS=https://farmmoo.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Media / File Storage ───────────────────────────────────────────────────────
# Set USE_S3=True to store uploaded files on Amazon S3 (or compatible service)
USE_S3=False

# Required when USE_S3=True:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=farmmoo-media
# AWS_S3_REGION_NAME=ap-southeast-1
# AWS_S3_CUSTOM_DOMAIN=          # Leave blank to use the default S3 URL

# ── Security (production only) ─────────────────────────────────────────────────
# Redirect all HTTP to HTTPS.  Set to False if TLS is terminated upstream.
# SECURE_SSL_REDIRECT=True
