# Frontend environment variables template
# Copy to .env.development or .env.production and fill in values.
# Only VITE_* variables are exposed to the browser bundle.

# Backend API base URL (no trailing slash)
# Dev:  http://127.0.0.1:8000/api
# Prod (Vercel+Render): https://farmmoo-marketplace.onrender.com/api
# Prod (local nginx): /api  (nginx same-origin proxy)
VITE_API_URL=http://127.0.0.1:8000/api

# Set to "true" to emit source maps in the production build (e.g., for staging)
# VITE_SOURCEMAP=false

# ════════════════════════════════════════════════════════════════════════════════
# VERCEL DEPLOYMENT
# ════════════════════════════════════════════════════════════════════════════════
#
# For Vercel + Render deployment:
# 1. Set in Vercel Dashboard → Environment Variables:
#    - VITE_API_URL=https://farmmoo-marketplace.onrender.com/api
#    - Environments: Production, Preview, Development
#
# 2. The .env.production file is used during build:
#    VITE_API_URL=https://farmmoo-marketplace.onrender.com/api
#
# See DEPLOYMENT.md for complete instructions

